# Python
__pycache__/
*.py[cod]
.venv/

# Downloaded datasets: keep dataset source code, ignore large local data files
/dataset/*.json
/dataset/*.jsonl
/dataset/*.parquet
/dataset/*.arrow
/dataset/*.npy
/dataset/*.npz

# Training outputs
/out/
/checkpoints/
*.pt
*.pth
*.safetensors

# Local experiment outputs: keep experiment code/data, ignore generated outputs
/experiments/**/outputs/

# Downloaded Transformers-format model directories
/minimind-3/
/scripts/minimind-3/

# Experiment platforms and local caches
wandb/
swanlog/
.runs/

# MiniMind local training artifacts
out/
checkpoints/
experiments/logs/
experiments/inference/
experiments/interrupted/
*.pth.tmp
*.pt.tmp
*.ckpt
*.ckpt.tmp
*.bin
*:Zone.Identifier
